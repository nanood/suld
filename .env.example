# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/sulddb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sulddb
DB_USER=postgres
DB_PASS=yourpassword

# Server Configuration
NODE_ENV=development
PORT=3000

# JWT Token (үүсгээрэй: https://random.org/)
ACCESS_TOKEN_SECRET=your_super_secret_key_here_change_this_in_production
REFRESH_TOKEN_SECRET=another_secret_key_here

# CORS (Production-д өөрчлөх)
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug
